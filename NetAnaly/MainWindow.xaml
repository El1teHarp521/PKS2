<Window x:Class="NetworkAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анализатор сети" Height="650" Width="1000" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Лево: Список интерфейсов -->
        <GroupBox Header="Сетевые адаптеры" Margin="0,0,10,0">
            <ListBox x:Name="lstInterfaces" SelectionChanged="InterfaceSelected"/>
        </GroupBox>

        <!-- Право: Всё остальное -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Детали интерфейса -->
            <GroupBox Header="Детали выбранного адаптера" Margin="0,0,0,10">
                <TextBlock x:Name="txtInterfaceInfo" Padding="10" Background="#F9F9F9" FontFamily="Consolas" TextWrapping="Wrap"/>
            </GroupBox>

            <!-- Работа с URL -->
            <GroupBox Header="Анализ URL / Ping / DNS" Grid.Row="1" Margin="0,0,0,10">
                <StackPanel Margin="10">
                    <DockPanel LastChildFill="True" Margin="0,0,0,10">
                        <TextBlock Text="URL:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="АНАЛИЗ" Click="AnalyzeUrl_Click" DockPanel.Dock="Right" Width="100" Margin="10,0,0,0"/>
                        <TextBox x:Name="txtUrlInput" Text="https://google.com"/>
                    </DockPanel>
                    <UniformGrid Columns="2">
                        <Button Content="PING" Click="Ping_Click" Height="30" Margin="0,0,5,0"/>
                        <Button Content="DNS INFO" Click="Dns_Click" Height="30" Margin="5,0,0,0"/>
                    </UniformGrid>
                </StackPanel>
            </GroupBox>

            <!-- Результат и История -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtResults" IsReadOnly="True" Background="Black" Foreground="Lime" FontFamily="Consolas" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                <GroupBox Header="История" Grid.Column="1" Margin="10,0,0,0">
                    <ListBox x:Name="lstHistory" DisplayMemberPath="Url"/>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</Window>