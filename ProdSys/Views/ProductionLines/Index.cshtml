@model IEnumerable<ProdSys.Models.ProductionLine>
@{ ViewData["Title"] = "Мониторинг"; }

<h2 class="fw-bold mb-4 text-uppercase">Мониторинг производственных линий</h2>

<div class="row g-4">
    @foreach (var line in Model)
    {
        <div class="col-md-6">
            <div class="card shadow border-0 h-100 @(line.Status == "Active" ? "border-primary border-top border-4" : "border-secondary border-top border-4")">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="fw-bold m-0">@line.Name</h4>
                        <div>
                            <span class="badge bg-dark">Разгон: @line.EfficiencyFactor.ToString("0.0")x</span>
                            <span class="badge @(line.Status == "Active" ? "bg-success" : "bg-secondary") ms-1">@line.Status</span>
                        </div>
                    </div>

                    <div class="flex-grow-1">
                        @{
                            var active = line.WorkOrders.Where(w => w.Status == "InProgress").ToList();
                            var queue = line.WorkOrders.Where(w => w.Status == "Pending").OrderBy(w => w.Id).ToList();
                        }

                        @if (active.Any())
                        {
                            foreach (var order in active)
                            {
                                double total = (order.EstimatedEndDate - order.StartDate).TotalSeconds;
                                double elapsed = (DateTime.Now - order.StartDate).TotalSeconds;
                                double prog = total > 0 ? (elapsed / total) * 100 : 100;
                                if (prog > 100) prog = 100; if (prog < 0) prog = 0;

                                <div class="p-2 mb-2 border rounded bg-white shadow-sm">
                                    <div class="d-flex justify-content-between small fw-bold mb-1">
                                        <span>@order.Product.Name (@order.Quantity шт.)</span>
                                        <span class="@(prog >= 100 ? "text-success" : "text-primary")">@((int)prog)%</span>
                                    </div>
                                    <div class="progress" style="height: 12px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated @(prog >= 100 ? "bg-success" : "bg-primary")" 
                                             style="width: @prog.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%;"></div>
                                    </div>
                                    @if(prog >= 100)
                                    {
                                        <form asp-action="CompleteOrder" method="post" class="mt-2">
                                            <input type="hidden" name="orderId" value="@order.Id" />
                                            <input type="hidden" name="lineId" value="@line.Id" />
                                            <button type="submit" class="btn btn-xs btn-success w-100 py-0 small fw-bold">ЗАВЕРШИТЬ</button>
                                        </form>
                                    }
                                </div>
                            }
                        }
                        else { <div class="text-center text-muted py-4">Линия простаивает</div> }
                    </div>

                    @if(queue.Any())
                    {
                        <div class="mt-2 mb-3 small text-muted bg-light p-1 rounded">
                            <i class="bi bi-clock-history"></i> В очереди: @queue.Count зак.
                        </div>
                    }

                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <form asp-action="StopLine" method="post">
                            <input type="hidden" name="lineId" value="@line.Id" />
                            <button type="submit" class="btn btn-sm btn-danger px-3">СТОП</button>
                        </form>

                        <form asp-action="UpdateEfficiency" method="post" class="d-flex">
                            <input type="hidden" name="lineId" value="@line.Id" />
                            <input type="number" name="efficiency" value="@line.EfficiencyFactor.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)" step="0.5" min="0.5" max="100.0" class="form-control form-control-sm me-1 text-center js-eff-input" style="width: 60px;" />
                            <button type="submit" class="btn btn-sm btn-primary">Разгон (0.5-2.0)</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        let isEditing = false;

        document.querySelectorAll('.js-eff-input').forEach(input => {
            input.addEventListener('focus', () => { isEditing = true; });
            input.addEventListener('blur', () => { isEditing = false; });
        });

        setInterval(() => {
            if (!isEditing) {
                location.reload();
            }
        }, 3000);
    </script>
}