@model IEnumerable<ProdSys.Models.Product>
@{
    ViewData["Title"] = "Продукты";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Панель продуктов</h2>
    <a asp-action="Create" class="btn btn-primary">Создать продукт</a>
</div>

<!-- Блок фильтрации и поиска -->
<div class="card shadow-sm border-0 mb-4 bg-light">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-bold">Поиск по названию:</label>
                <input type="text" name="searchString" class="form-control" placeholder="Введите название...">
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">Фильтр по категории:</label>
                <select name="category" class="form-select">
                    <option value="">Все категории</option>
                    @if(ViewBag.Categories != null)
                    {
                        foreach (var cat in ViewBag.Categories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-dark w-100">Применить фильтры</button>
            </div>
        </form>
    </div>
</div>

<!-- Таблица продуктов -->
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Название</th>
                    <th>Категория</th>
                    <th>Время производства (мин/шт)</th>
                    <th>Мин. запас</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="align-middle">
                        <td class="fw-bold text-primary">@item.Name</td>
                        <td><span class="badge bg-secondary">@item.Category</span></td>
                        <td><i class="bi bi-clock"></i> @item.ProductionTimePerUnit мин.</td>
                        <td>@item.MinimalStock шт.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>