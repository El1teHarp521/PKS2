@model ProdSys.Models.Product
@{
    ViewData["Title"] = "Создать продукт";
}

<h2 class="fw-bold mb-4">Создание нового продукта</h2>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Название продукта</label>
                            <input asp-for="Name" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Категория</label>
                            <input asp-for="Category" class="form-control" placeholder="Например: Электроника" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Описание</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Время производства (в минутах)</label>
                            <input asp-for="ProductionTimePerUnit" type="number" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Минимальный запас на складе</label>
                            <input asp-for="MinimalStock" type="number" class="form-control" required />
                        </div>
                    </div>

                    <hr />
                    <h5 class="fw-bold mb-3">Привязка материалов</h5>
                    <div class="mb-4">
                        <label class="form-label text-muted">Зажмите Ctrl, чтобы выбрать несколько материалов, необходимых для сборки этого продукта.</label>
                        <select name="selectedMaterials" asp-items="ViewBag.Materials" class="form-select" multiple size="4">
                        </select>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                        <button type="submit" class="btn btn-primary px-5">Сохранить продукт</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>