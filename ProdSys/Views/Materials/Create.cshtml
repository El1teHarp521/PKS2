@model ProdSys.Models.Material
@{
    ViewData["Title"] = "Добавить материал";
}

<h2 class="fw-bold mb-4">Добавление материала</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Название материала</label>
                        <input asp-for="Name" class="form-control" placeholder="Например: Алюминий" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Текущее количество на складе</label>
                        <input asp-for="Quantity" type="number" step="0.01" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Единица измерения</label>
                        <select asp-for="UnitOfMeasure" class="form-select" required>
                            <option value="шт">шт</option>
                            <option value="кг">кг</option>
                            <option value="литр">литр</option>
                            <option value="м">метр</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Минимальный допустимый запас</label>
                        <input asp-for="MinimalStock" type="number" step="0.01" class="form-control" required />
                        <div class="form-text">Если количество опустится ниже этого значения, материал загорится красным.</div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">Отмена</a>
                        <button type="submit" class="btn btn-primary">Сохранить материал</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>