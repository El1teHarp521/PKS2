@model IEnumerable<ProdSys.Models.Material>
@{
    ViewData["Title"] = "Склад материалов";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Панель материалов</h2>
    <a asp-action="Create" class="btn btn-primary">Добавить новый материал</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Название</th>
                    <th>Текущее количество</th>
                    <th>Ед. измерения</th>
                    <th>Минимальный запас</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    // Логика цветовой индикации: если количество меньше или равно минимальному
                    bool isLowStock = item.Quantity <= item.MinimalStock;
                    string rowClass = isLowStock ? "table-danger" : "";

                    <tr class="@rowClass align-middle">
                        <td class="fw-bold">@item.Name</td>
                        <td>
                            <span class="fs-5">@item.Quantity</span>
                            @if (isLowStock)
                            {
                                <span class="badge bg-danger ms-2"><i class="bi bi-exclamation-triangle"></i> Низкий запас!</span>
                            }
                        </td>
                        <td>@item.UnitOfMeasure</td>
                        <td>@item.MinimalStock</td>
                        <td>
                            <!-- Форма быстрого пополнения -->
                            <form asp-action="Replenish" method="post" class="d-flex align-items-center">
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="number" name="amount" value="50" min="1" class="form-control form-control-sm me-2" style="width: 80px;" title="Количество для пополнения" />
                                <button type="submit" class="btn btn-sm btn-success">Пополнить</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>