@model TouristGuide.Models.Attraction
@{ ViewData["Title"] = Model.Name; }

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="mb-4">
                <a asp-controller="Cities" asp-action="Details" asp-route-id="@Model.CityId" class="btn btn-light shadow-sm">
                    &larr; Назад к городу @Model.City.Name
                </a>
            </div>

            <article class="card border-0 shadow-lg overflow-hidden rounded-4">
                <img src="@Model.PhotoUrl" class="img-fluid w-100" alt="@Model.Name" style="max-height: 500px; object-fit: cover;">
                
                <div class="card-body p-lg-5">
                    <h1 class="display-5 fw-bold mb-3">@Model.Name</h1>
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        <span class="badge bg-primary px-3 py-2">Достопримечательность</span>
                        <span class="badge bg-outline-secondary px-3 py-2 text-dark border">@Model.City.Name</span>
                    </div>

                    <p class="fs-5 text-secondary mb-5" style="line-height: 1.8;">@Model.History</p>

                    <div class="row g-4 bg-light p-4 rounded-4">
                        <div class="col-md-6">
                            <h5 class="fw-bold"><i class="bi bi-clock me-2 text-primary"></i>Режим работы</h5>
                            <p class="mb-0">@Model.WorkingHours</p>
                        </div>
                        <div class="col-md-6">
                            <h5 class="fw-bold"><i class="bi bi-cash-stack me-2 text-primary"></i>Стоимость билета</h5>
                            <p class="mb-0">@Model.TicketPrice</p>
                        </div>
                    </div>
                </div>
            </article>
        </div>
    </div>
</div>