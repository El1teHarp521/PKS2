<Window x:Class="LibraryProject.GenreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Жанры" Height="350" Width="450" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="180"/>
        </Grid.ColumnDefinitions>
        <ListBox x:Name="lstGenres" DisplayMemberPath="Name"/>
        <StackPanel Grid.Column="1" Margin="10,0,0,0">
            <TextBlock Text="Название жанра:"/>
            <TextBox x:Name="txtName" Margin="0,0,0,5"/>
            <TextBlock Text="Описание:"/>
            <TextBox x:Name="txtDesc" Height="80" TextWrapping="Wrap" Margin="0,0,0,10"/>
            <Button Content="Добавить жанр" Click="Add_Click" Margin="0,0,0,5" Height="30" Background="LightGreen"/>
            <Button Content="Удалить" Click="Delete_Click" Height="30" Background="LightGray"/>
        </StackPanel>
    </Grid>
</Window>