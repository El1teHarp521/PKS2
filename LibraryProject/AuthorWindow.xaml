<Window x:Class="LibraryProject.AuthorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторы" Height="350" Width="450" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="180"/>
        </Grid.ColumnDefinitions>
        <ListBox x:Name="lstAuthors" DisplayMemberPath="FullName"/>
        <StackPanel Grid.Column="1" Margin="10,0,0,0">
            <TextBlock Text="Имя:"/>
            <TextBox x:Name="txtFirst" Margin="0,0,0,5"/>
            <TextBlock Text="Фамилия:"/>
            <TextBox x:Name="txtLast" Margin="0,0,0,10"/>
            <Button Content="Добавить автора" Click="Add_Click" Margin="0,0,0,5" Height="30" Background="LightGreen"/>
            <Button Content="Удалить" Click="Delete_Click" Height="30" Background="LightGray"/>
        </StackPanel>
    </Grid>
</Window>