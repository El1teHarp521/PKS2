<Window x:Class="LibraryProject.BookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Данные книги" Height="580" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="Название книги:"/>
            <TextBox x:Name="txtTitle" Margin="0,5,0,10"/>

            <TextBlock Text="Авторы (Ctrl + Клик для выбора нескольких):"/>
            <ListBox x:Name="lstAuthors" DisplayMemberPath="FullName" Height="100" SelectionMode="Multiple" Margin="0,5,0,10"/>

            <TextBlock Text="Жанры (Ctrl + Клик для выбора нескольких):"/>
            <ListBox x:Name="lstGenres" DisplayMemberPath="Name" Height="100" SelectionMode="Multiple" Margin="0,5,0,10"/>

            <TextBlock Text="ISBN (ровно 13 цифр):"/>
            <TextBox x:Name="txtISBN" Margin="0,5,0,10"/>

            <TextBlock Text="Год / Количество на складе:"/>
            <UniformGrid Columns="2">
                <TextBox x:Name="txtYear" Margin="0,0,5,0"/>
                <TextBox x:Name="txtQuantity" Margin="5,0,0,0"/>
            </UniformGrid>

            <Button Content="СОХРАНИТЬ" Click="Save_Click" Height="40" Margin="0,20,0,0" 
                    Background="AliceBlue" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>