<Window x:Class="MonitorSys.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Система мониторинга HTTP" Height="700" Width="1100" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ЧАСТЬ: СЕРВЕР -->
        <GroupBox Header="HTTP СЕРВЕР" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>

<StackPanel Orientation="Horizontal" Margin="0,5">
    <TextBlock Text="Порт:" VerticalAlignment="Center" Margin="0,0,5,0"/>
    <TextBox x:Name="txtServerPort" Text="8080" Width="60" Margin="0,0,10,0"/>
    <Button x:Name="btnStartServer" Content="Запустить" Click="StartServer_Click" Padding="10,2" Margin="0,0,5,0"/>
    <Button x:Name="btnStopServer" Content="Остановить" Click="StopServer_Click" Padding="10,2" IsEnabled="False"/>
</StackPanel>

                <GroupBox Header="Статистика" Grid.Row="1" Margin="0,5">
                    <UniformGrid Columns="2" Margin="5">
                        <TextBlock x:Name="lblGetCount" Text="GET запросов: 0"/>
                        <TextBlock x:Name="lblPostCount" Text="POST запросов: 0"/>
                        <TextBlock x:Name="lblUptime" Text="Работает: 0 сек"/>
                        <TextBlock x:Name="lblAvgTime" Text="Ср. время: 0 мс"/>
                    </UniformGrid>
                </GroupBox>

                <GroupBox Header="Логи сервера" Grid.Row="2">
                    <ListBox x:Name="lstServerLogs"/>
                </GroupBox>

                <GroupBox Header="Принятые сообщения (JSON)" Grid.Row="3">
                    <ListBox x:Name="lstMessages"/>
                </GroupBox>
            </Grid>
        </GroupBox>

        <!-- ПРАВАЯ ЧАСТЬ: КЛИЕНТ -->
        <GroupBox Header="HTTP КЛИЕНТ" Grid.Column="1" Margin="5">
            <StackPanel>
                <TextBlock Text="URL назначения:"/>
                <TextBox x:Name="txtClientUrl" Text="http://localhost:8080" Margin="0,5"/>

                <TextBlock Text="Метод:"/>
                <ComboBox x:Name="cbMethod" SelectedIndex="0" Margin="0,5">
                    <ComboBoxItem Content="GET"/>
                    <ComboBoxItem Content="POST"/>
                </ComboBox>

                <TextBlock Text="Тело запроса (JSON для POST):"/>
                <TextBox x:Name="txtClientBody" Height="100" TextWrapping="Wrap" AcceptsReturn="True" 
                         Text="{}{ 'message': 'Привет от клиента' }" Margin="0,5"/>

                <Button Content="Отправить запрос" Click="SendRequest_Click" Height="35" Margin="0,10" Background="LightBlue"/>

                <TextBlock Text="Ответ от сервера:"/>
                <TextBox x:Name="txtClientResponse" Height="200" IsReadOnly="True" Background="#F0F0F0" 
                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>